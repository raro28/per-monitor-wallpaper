{
  "name": "per-monitor-wallpaper",
  "version": "2.2.0",
  "description": "GNOME Shell extension: per-monitor wallpaper",
  "type": "module",
  "private": true,
  "license": "GPL-3.0-or-later",
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --format=esm --outdir=dist '--external:gi://*' '--external:resource://*' && cp src/metadata.json dist/",
    "check": "tsc --noEmit",
    "lint": "eslint src",
    "test": "rm -rf .test-build && esbuild src/lib/*.test.ts --bundle --format=esm --platform=node --outdir=.test-build && node --test '.test-build/*.js'"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@girs/gnome-shell": "^50.0.2",
    "esbuild": "^0.28.1",
    "eslint": "^9.13.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.61.1"
  }
}
